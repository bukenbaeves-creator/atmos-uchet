// Prisma schema — приложение учёта клиники ATMOS
// Категориальные поля хранятся строкой (совместимо с исходными Excel) и
// валидируются по таблице DictionaryItem в сервисном слое. Вычисляемые поля
// (total_due, paid, balance, fully_paid, month, конверсия, выручка) не хранятся —
// считаются в сервисном слое, чтобы исключить расхождения.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  operator
  nurse
}

// Тип позиции номенклатуры
enum NomenclatureType {
  drug // препарат (учёт партий и срока годности)
  consumable // расходник
}

// Статус позиции номенклатуры: draft — ждёт подтверждения администратором
enum NomenclatureStatus {
  draft
  active
}

// Источник документа прихода
enum ReceiptSource {
  manual
  import
  revision // служебный приход: оприходование излишка по ревизии
}

// Статус ревизии склада: draft — вводятся факт. остатки; applied — корректировки проведены
enum RevisionStatus {
  draft
  applied
}

// Статус прихода: pending — создан медсестрой, ждёт одобрения админа (партии ещё не
// созданы, на остаток не влияет); approved — одобрен/создан админом (партии созданы).
enum ReceiptStatus {
  pending
  approved
}

// Направление денежной операции: платёж (приход) или возврат (расход пациенту)
enum PaymentDirection {
  payment
  refund
}

model User {
  id             Int       @id @default(autoincrement())
  login          String    @unique
  fio            String
  role           Role      @default(operator)
  passwordHash   String
  active         Boolean   @default(true)
  failedAttempts Int       @default(0) // подряд неверных попыток входа
  lockedUntil    DateTime? // временная блокировка входа при переборе
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Универсальный справочник. category: city | doctor | surgeon | op_type |
// pay_method | terminal | service_type | consultation_stage | vid | zapis
model DictionaryItem {
  id        Int      @id @default(autoincrement())
  category  String
  label     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, label])
  @@index([category])
}

model Patient {
  id        Int       @id @default(autoincrement())
  fio       String
  birthDate DateTime?
  phone     String    @unique
  city      String?

  consultations Consultation[]
  operations    Operation[]
  payments      Payment[]
  writeoffs     ExpenseWriteoff[]

  mergedIntoId Int? // если карточка слита с другой — id основной карточки

  createdBy Int?
  createdAt DateTime  @default(now())
  updatedBy Int?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy Int?

  @@index([fio])
}

model Consultation {
  id                Int       @id @default(autoincrement())
  patient           Patient   @relation(fields: [patientId], references: [id])
  patientId         Int
  dateZapis         DateTime?
  dateKons          DateTime?
  time              String?
  vid               String?
  interestOperation String?
  doctor            String?
  manager           String? // менеджер, записавший на консультацию (для KPI)
  stage             String?
  resultDetails     String?
  payDate           DateTime?
  payMethod         String?
  terminal          String?
  payNote           String?
  amount            Decimal?  @db.Decimal(14, 2)

  operations Operation[]
  payments   Payment[]

  createdBy Int?
  createdAt DateTime  @default(now())
  updatedBy Int?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy Int?

  @@index([patientId])
  @@index([stage])
  @@index([dateKons])
}

model Operation {
  id               Int           @id @default(autoincrement())
  patient          Patient       @relation(fields: [patientId], references: [id])
  patientId        Int
  consultation     Consultation? @relation(fields: [consultationId], references: [id])
  consultationId   Int?
  zapis            String?
  manager          String? // менеджер, записавший на операцию (для KPI)
  dateOp           DateTime?
  opType           String?
  surgeon          String?
  anesthesiologist String?
  cost             Decimal       @default(0) @db.Decimal(14, 2)
  anesthesiaCost   Decimal       @default(0) @db.Decimal(14, 2)
  contractSigned   Boolean       @default(false)
  note             String?

  payments  Payment[]
  writeoffs ExpenseWriteoff[]

  createdBy Int?
  createdAt DateTime  @default(now())
  updatedBy Int?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy Int?

  @@index([patientId])
  @@index([dateOp])
}

model Payment {
  id             Int              @id @default(autoincrement())
  patient        Patient          @relation(fields: [patientId], references: [id])
  patientId      Int
  operation      Operation?       @relation(fields: [operationId], references: [id])
  operationId    Int?
  consultation   Consultation?    @relation(fields: [consultationId], references: [id])
  consultationId Int? // платёж, привязанный к консультации (синхронизация поздней оплаты)
  direction      PaymentDirection @default(payment)
  date           DateTime?
  serviceType    String?
  opType         String? // вид операции — заполняется, если услуга «Операция»/«Консультация»
  amount         Decimal          @default(0) @db.Decimal(14, 2)
  payMethod      String?
  terminal       String?
  payNote        String?
  zapis          String?
  doctor         String?

  createdBy Int?
  createdAt DateTime  @default(now())
  updatedBy Int?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy Int?

  @@index([patientId])
  @@index([operationId])
  @@index([consultationId])
  @@index([date])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  userFio   String?
  action    String // create | update | delete | restore | login
  entity    String
  entityId  Int?
  before    Json?
  after     Json?
  ip        String?
  timestamp DateTime @default(now())

  @@index([entity, entityId])
  @@index([timestamp])
}

// Настройки приложения (ключ-значение). Используется для ставок KPI.
model Setting {
  key   String @id
  value String
}

// ===== Модуль учёта материальных расходов =====

// Позиция номенклатуры (препарат/расходник). Наполняется из приходов; новые
// позиции попадают в draft и подтверждаются администратором (модерация).
model Nomenclature {
  id              Int                @id @default(autoincrement())
  nameDisplay     String
  nameNormalized  String             @unique // нормализованное имя для сопоставления
  type            NomenclatureType   @default(consumable)
  unitMeasure     String? // ед. измерения (мл, мг, шт)
  unitWriteoff    String? // ед. списания
  packFactor      Decimal            @default(1) @db.Decimal(14, 4) // упаковка -> ед. списания
  minStock        Decimal            @default(0) @db.Decimal(14, 3) // точка дозаказа
  isSpecial       Boolean            @default(false) // контролируемый препарат
  isExpiryTracked Boolean            @default(false) // учёт срока годности (FEFO)
  status          NomenclatureStatus @default(draft)
  confirmedBy     Int?
  confirmedAt     DateTime?
  mergedIntoId    Int? // если позиция слита с другой — id основной позиции

  aliases       NomenclatureAlias[]
  batches       Batch[]
  writeoffs     ExpenseWriteoff[]
  revisionItems RevisionItem[]

  createdBy Int?
  createdAt DateTime  @default(now())
  updatedBy Int?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy Int?

  @@index([status])
}

// Варианты написания наименования (синонимы), накапливаются из приходов.
model NomenclatureAlias {
  id              Int          @id @default(autoincrement())
  nomenclature    Nomenclature @relation(fields: [nomenclatureId], references: [id])
  nomenclatureId  Int
  aliasRaw        String // исходное написание из прихода
  aliasNormalized String       @unique // нормализованный вариант (ключ поиска)
  createdAt       DateTime     @default(now())

  @@index([nomenclatureId])
}

// Категория расхода (операция/реабилитация). Расширяемый справочник.
model ExpenseCategory {
  id        Int               @id @default(autoincrement())
  name      String            @unique
  isActive  Boolean           @default(true)
  sortOrder Int               @default(0)
  writeoffs ExpenseWriteoff[]
}

// Документ прихода на склад.
model Receipt {
  id         Int           @id @default(autoincrement())
  date       DateTime
  source     ReceiptSource @default(manual)
  status     ReceiptStatus @default(approved) // pending — приход медсестры на согласовании
  supplier   String? // наименование поставщика
  note       String?
  importHash String? // sha256 файла импорта — контроль повторной загрузки (точный дубль файла)
  contentHash String? // сигнатура состава (позиции+кол-во) — ловит повторную загрузку изменённого файла
  batches    Batch[]
  lines      ReceiptLine[] // предложенные строки, пока приход на согласовании (партии ещё не созданы)

  approvedBy Int?
  approvedAt DateTime?
  createdBy  Int?
  createdAt  DateTime  @default(now())
  updatedBy  Int?
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  deletedBy  Int?
}

// Предложенная строка прихода «на согласовании» (до одобрения партии не создаются,
// чтобы непроверенные данные не попадали в остаток/себестоимость). При одобрении из
// строк создаются партии, а сами строки удаляются.
model ReceiptLine {
  id            Int               @id @default(autoincrement())
  receipt       Receipt           @relation(fields: [receiptId], references: [id])
  receiptId     Int
  name          String // сырое наименование (как ввела медсестра)
  qty           Decimal           @db.Decimal(14, 3)
  purchasePrice Decimal           @db.Decimal(14, 2)
  series        String?
  expiryDate    DateTime?
  type          NomenclatureType? // предложенный тип позиции (расходник/препарат)
  minStock      Decimal?          @db.Decimal(14, 3) // предложенный минимальный остаток
  unit          String? // предложенная единица

  @@index([receiptId])
}

// Партия прихода: цена закупа, серия, срок годности, текущий остаток.
model Batch {
  id             Int          @id @default(autoincrement())
  receipt        Receipt      @relation(fields: [receiptId], references: [id])
  receiptId      Int
  nomenclature   Nomenclature @relation(fields: [nomenclatureId], references: [id])
  nomenclatureId Int
  qtyIn          Decimal      @db.Decimal(14, 3)
  qtyRemaining   Decimal      @db.Decimal(14, 3)
  purchasePrice  Decimal      @db.Decimal(14, 2) // цена закупа за единицу (только админ)
  series         String?
  expiryDate     DateTime?
  receivedAt     DateTime

  allocations WriteoffBatchAllocation[]

  createdBy Int?
  createdAt DateTime @default(now())

  @@index([nomenclatureId, expiryDate, receivedAt])
}

// Списание материала на пациента/операцию. costTotal фиксируется в момент списания.
model ExpenseWriteoff {
  id             Int             @id @default(autoincrement())
  patient        Patient         @relation(fields: [patientId], references: [id])
  patientId      Int
  operation      Operation?      @relation(fields: [operationId], references: [id])
  operationId    Int?
  nomenclature   Nomenclature    @relation(fields: [nomenclatureId], references: [id])
  nomenclatureId Int
  category       ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId     Int
  qty            Decimal         @db.Decimal(14, 3) // в единице списания
  costTotal      Decimal         @default(0) @db.Decimal(14, 2) // зафиксированная себестоимость (только админ)
  isShortage     Boolean         @default(false) // списано при нехватке остатка
  date           DateTime

  allocations WriteoffBatchAllocation[]

  createdBy Int?
  createdAt DateTime  @default(now())
  updatedBy Int?
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  deletedBy Int?

  @@index([patientId])
  @@index([operationId])
  @@index([nomenclatureId])
  @@index([date])
}

// Распределение одного списания по партиям (ядро FIFO/FEFO).
model WriteoffBatchAllocation {
  id         Int             @id @default(autoincrement())
  writeoff   ExpenseWriteoff @relation(fields: [writeoffId], references: [id])
  writeoffId Int
  batch      Batch           @relation(fields: [batchId], references: [id])
  batchId    Int
  qty        Decimal         @db.Decimal(14, 3)
  cost       Decimal         @db.Decimal(14, 2) // qty × purchasePrice (только админ)

  @@index([writeoffId])
  @@index([batchId])
}

// Ревизия (инвентаризация) склада: сверка фактических остатков с учётными и
// корректировка. Черновик заполняет медсестра/админ; применяет только админ.
model Revision {
  id        Int            @id @default(autoincrement())
  date      DateTime       @default(now())
  note      String?
  status    RevisionStatus @default(draft)
  items     RevisionItem[]
  createdBy Int?
  createdAt DateTime       @default(now())
  updatedBy Int?
  updatedAt DateTime       @updatedAt
  appliedBy Int?
  appliedAt DateTime?
  deletedAt DateTime?
  deletedBy Int?
}

// Позиция ревизии: один материал. systemQty — учётный остаток (снимок), countedQty —
// фактический (null = не считали, не трогаем при применении), surplusPrice — цена
// излишка (вручную), costDelta — денежный эффект корректировки (заполняется при применении).
model RevisionItem {
  id             Int          @id @default(autoincrement())
  revision       Revision     @relation(fields: [revisionId], references: [id])
  revisionId     Int
  nomenclature   Nomenclature @relation(fields: [nomenclatureId], references: [id])
  nomenclatureId Int
  systemQty      Decimal      @db.Decimal(14, 3)
  countedQty     Decimal?     @db.Decimal(14, 3)
  surplusPrice   Decimal?     @db.Decimal(14, 2) // цена излишка (только админ)
  costDelta      Decimal?     @db.Decimal(14, 2) // эффект: <0 недостача, >0 излишек (только админ)
  note           String?

  @@unique([revisionId, nomenclatureId])
  @@index([revisionId])
}
